{
  "name": "@salesforce/salesforcedx-utils-vscode",
  "displayName": "SFDX Utilities for VS Code",
  "description": "Provides utilities to interface the SFDX libraries with VS Code",
  "version": "65.7.0",
  "publisher": "salesforce",
  "license": "BSD-3-Clause",
  "categories": [
    "Other"
  ],
  "main": "out/src",
  "dependencies": {
    "@salesforce/core": "^8.28.0",
    "@salesforce/effect-ext-utils": "*",
    "@salesforce/o11y-reporter": "^1.8.1",
    "@salesforce/salesforcedx-utils": "*",
    "@salesforce/vscode-i18n": "*",
    "@salesforce/vscode-service-provider": "^1.5.0",
    "@vscode/extension-telemetry": "^1.0.0",
    "applicationinsights": "1.0.7",
    "cross-spawn": "7.0.6",
    "effect": "^3.20.0",
    "o11y_schema": "^260.44.0",
    "rxjs": "^7.8.2",
    "tree-kill": "^1.1.0",
    "vscode-uri": "^3.1.0",
    "zod": "^4.3.2"
  },
  "devDependencies": {},
  "engines": {
    "vscode": "^1.90.0"
  },
  "scripts": {
    "compile": "wireit",
    "lint": "wireit",
    "clean": "shx rm -rf node_modules out dist coverage .nyc_output .wireit .eslintcache",
    "test": "wireit",
    "test:compile": "wireit"
  },
  "wireit": {
    "compile": {
      "command": "tsc --pretty",
      "clean": "if-file-deleted",
      "dependencies": [
        "../salesforcedx-utils:compile",
        "../salesforcedx-vscode-i18n:compile",
        "../effect-ext-utils:compile"
      ],
      "files": [
        "src/**/*.ts",
        "tsconfig.json",
        "../../tsconfig.common.json",
        "package.json"
      ],
      "output": [
        "out/**",
        "tsconfig.tsbuildinfo"
      ]
    },
    "test:compile": {
      "command": "tsc -p test/tsconfig.json",
      "dependencies": [
        "compile"
      ],
      "files": [
        "test/**/*.ts",
        "test/tsconfig.json"
      ],
      "output": []
    },
    "test": {
      "command": "jest --coverage",
      "dependencies": [
        "test:compile"
      ],
      "files": [
        "test/**/*.ts",
        "jest.config.js",
        "../../config/jest.base.config.js"
      ],
      "output": [
        "coverage"
      ]
    },
    "lint": {
      "command": "eslint --color --cache --cache-location .eslintcache .",
      "dependencies": [
        "../eslint-local-rules:compile"
      ],
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        "../../eslint.config.mjs",
        "package.json",
        "package.nls.json"
      ],
      "output": []
    }
  }
}
