/* Nested subquery: inner Cases envelope is one column per Contact row in the extension
   (not extra grid rows). Run seed-nested-subquery-test.apex first. */
SELECT
  Id,
  Name,
  (
    SELECT
      Id,
      FirstName,
      LastName,
      (
        SELECT Id, Subject, Status
        FROM Cases
        ORDER BY Subject
        LIMIT 20
      )
    FROM Contacts
    ORDER BY LastName
    LIMIT 50
  )
FROM Account
WHERE Name = 'VSE_NestedSub_Root'
