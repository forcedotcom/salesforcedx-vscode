{
  "extends": "../../tsconfig.common.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "out",
    "strict": false,
    "noImplicitAny": false,
    "paths": {
      "@salesforce/soql-model/*": ["./src/soql-model/*"]
    }
  },
  "exclude": [
    "node_modules",
    ".vscode-test",
    "out",
    "./test/ui-test/resources/extensions",
    "dist",
    "src/soql-builder-ui",
    "test/jest/soql-builder-ui"
  ],
  "include": [
    "src/**/*.ts",
    "test/playwright/**/*.ts",
    "playwright.config.desktop.ts",
    "package.json",
    "package.nls.json"
  ],
  "references": [
    {
      "path": "../effect-ext-utils"
    },
    {
      "path": "../salesforcedx-utils"
    },
    {
      "path": "../salesforcedx-utils-vscode"
    },
    {
      "path": "../salesforcedx-vscode-i18n"
    },
    {
      "path": "../salesforcedx-vscode-core"
    },
    {
      "path": "../playwright-vscode-ext"
    },
    {
      "path": "../salesforcedx-vscode-services"
    },
    {
      "path": "../soql-common"
    }
  ]
}
