{
  "extends": "../../tsconfig.common.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "out",
    "isolatedModules": true,
    "noImplicitAny": true,
    "paths": {
      "@salesforce/soql-model/*": ["./src/soql-model/*"]
    }
  },
  "exclude": ["src/soql-builder-ui"],
  "include": [
    "src/**/*.ts",
    "package.json",
    "package.nls.json"
  ],
  "references": [
    {
      "path": "../effect-ext-utils"
    },
    {
      "path": "../salesforcedx-vscode-i18n"
    },
    {
      "path": "../playwright-vscode-ext"
    },
    {
      "path": "../salesforcedx-vscode-services"
    },
    {
      "path": "../soql-common"
    }
  ]
}
