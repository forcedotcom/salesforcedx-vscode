{
  "extends": "../../tsconfig.common.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "out",
    "strict": false,
    "noImplicitAny": false,
    "paths": {
      "@salesforce/soql-model/*": [
        "./src/soql-model/*"
      ]
    }
  },
  "exclude": [
    "node_modules",
    ".vscode-test",
    "out",
    "./test/ui-test/resources/extensions",
    "dist",
    "src/soql-builder-ui",
    "test/jest/soql-builder-ui"
  ],
  "include": [
    "src/**/*.ts"
  ],
  "references": [
    {
      "path": "../soql-common"
    },
    {
      "path": "../salesforcedx-utils-vscode"
    },
    {
      "path": "../soql-common"
    },
    {
      "path": "../salesforcedx-vscode-i18n"
    },
    {
      "path": "../salesforcedx-utils"
    },
    {
      "path": "../salesforcedx-vscode-core"
    },
    {
      "path": "../salesforcedx-vscode-services"
    }
  ]
