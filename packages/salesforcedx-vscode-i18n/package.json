{
  "name": "@salesforce/vscode-i18n",
  "version": "66.7.0",
  "versionedIndependently": true,
  "description": "Internationalization (i18n) library for Salesforce VS Code extensions",
  "author": "Salesforce",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/forcedotcom/salesforcedx-vscode"
  },
  "bugs": {
    "url": "https://github.com/forcedotcom/salesforcedx-vscode/issues"
  },
  "homepage": "https://github.com/forcedotcom/salesforcedx-vscode/tree/develop/packages/salesforcedx-vscode-i18n",
  "main": "out/src/index.js",
  "types": "out/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./out/src/index.d.ts",
      "default": "./out/src/index.js"
    },
    "./tsPlugin": {
      "types": "./out/src/hover/tsPlugin.d.ts",
      "default": "./out/src/hover/tsPlugin.js"
    }
  },
  "files": [
    "tsPlugin.js",
    "out/src/**/*.js",
    "out/src/**/*.js.map",
    "out/src/**/*.d.ts",
    "out/src/**/*.d.ts.map",
    "LICENSE.txt",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "compile": "wireit",
    "lint": "wireit",
    "check:circular-deps": "wireit",
    "clean": "shx rm -rf node_modules out dist coverage .wireit .eslintcache .circular-deps.json",
    "test": "wireit",
    "test:compile": "wireit"
  },
  "wireit": {
    "compile": {
      "command": "tsc --pretty",
      "clean": "if-file-deleted",
      "files": [
        "src/**/*.ts",
        "tsconfig.json",
        "../../tsconfig.common.json",
        "package.json"
      ],
      "output": [
        "out/**"
      ]
    },
    "test:compile": {
      "command": "tsc -p test/tsconfig.json",
      "dependencies": [
        "compile"
      ],
      "files": [
        "test/**/*.ts",
        "test/tsconfig.json"
      ],
      "output": []
    },
    "test": {
      "command": "jest --coverage",
      "dependencies": [
        "test:compile"
      ],
      "files": [
        "test/**/*.ts",
        "jest.config.js",
        "../../config/jest.base.config.js"
      ],
      "output": [
        "coverage"
      ]
    },
    "lint": {
      "command": "eslint --color --cache --cache-location .eslintcache .",
      "dependencies": [
        "check:circular-deps",
        "../eslint-local-rules:compile"
      ],
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        "../../eslint.config.mjs",
        "package.json",
        "package.nls.json"
      ],
      "output": []
    },
    "check:circular-deps": {
      "command": "dpdm --no-warning --no-tree --exit-code circular:1 --output .circular-deps.json src/index.ts",
      "dependencies": [
        "compile"
      ],
      "files": [
        "src/**/*.ts"
      ],
      "output": [
        ".circular-deps.json"
      ]
    }
  }
}
