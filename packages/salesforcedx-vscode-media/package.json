{
  "name": "salesforcedx-vscode-media",
  "displayName": "Salesforce Shared Media",
  "description": "Shared fonts and icons for Salesforce extensions",
  "qna": "https://github.com/forcedotcom/salesforcedx-vscode/issues",
  "bugs": {
    "url": "https://github.com/forcedotcom/salesforcedx-vscode/issues"
  },
  "repository": {
    "url": "https://github.com/forcedotcom/salesforcedx-vscode"
  },
  "version": "65.18.0",
  "publisher": "salesforce",
  "license": "BSD-3-Clause",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "devDependencies": {
    "@types/fontkit": "^2.0.8",
    "@types/jest": "^29.5.5",
    "fontkit": "^2.0.4",
    "jest": "^29.7.0",
    "jest-junit": "14.0.1",
    "svgtofont": "^6.5.0",
    "ts-jest": "^29.4.1"
  },
  "scripts": {
    "build:icons": "wireit",
    "compile": "wireit",
    "vscode:package": "wireit",
    "vscode:sha256": "node ../../scripts/generate-sha256.js >> ../../SHA256",
    "vscode:publish": "node ../../scripts/publish-vsix.js",
    "clean": "shx rm -rf node_modules out .wireit .eslintcache *.vsix",
    "test": "wireit",
    "lint": "wireit"
  },
  "wireit": {
    "build:icons": {
      "command": "node scripts/build-icons.mjs",
      "files": [
        "scripts/build-icons.mjs",
        "media/icons-src/*.svg"
      ],
      "output": [
        "out/icons-font/**"
      ]
    },
    "compile": {
      "command": "tsc --build --pretty",
      "clean": "if-file-deleted",
      "dependencies": [
        "build:icons",
        "../salesforcedx-vscode-i18n:compile"
      ],
      "files": [
        "src/**/*.ts",
        "tsconfig.json",
        "../../tsconfig.common.json",
        "package.json"
      ],
      "output": [
        "out/src/**",
        "out/test/**",
        "tsconfig.tsbuildinfo"
      ]
    },
    "vscode:package": {
      "command": "vsce package --allow-package-all-secrets",
      "dependencies": [
        "compile"
      ],
      "files": [
        "package.json",
        "README.md",
        "CHANGELOG.md",
        "LICENSE.txt",
        "media/**",
        "out/**"
      ],
      "output": [
        "*.vsix"
      ]
    },
    "test": {
      "command": "jest --coverage",
      "dependencies": [
        "compile"
      ],
      "files": [
        "test/**/*.ts",
        "package.json",
        "jest.config.js",
        "../../config/jest.base.config.js"
      ],
      "output": [
        "coverage"
      ]
    },
    "lint": {
      "command": "eslint --color --cache --cache-location .eslintcache .",
      "dependencies": [
        "../eslint-local-rules:compile"
      ],
      "files": [
        "test/**/*.ts",
        "../../eslint.config.mjs",
        "package.json"
      ],
      "output": []
    }
  },
  "contributes": {
    "icons": {
      "sf-org-leaf": {
        "description": "Leaf icon for default scratch org",
        "default": {
          "fontPath": "out/icons-font/sf-media-icons.woff",
          "fontCharacter": "\\E001"
        }
      },
      "sf-org-tree": {
        "description": "Tree icon for default dev hub",
        "default": {
          "fontPath": "out/icons-font/sf-media-icons.woff",
          "fontCharacter": "\\E002"
        }
      }
    }
  },
  "main": "out/src/icons.js",
  "types": "out/src/icons.d.ts",
  "exports": {
    ".": {
      "types": "./out/src/icons.d.ts",
      "default": "./out/src/icons.js"
    }
  },
  "dependencies": {
    "@salesforce/vscode-i18n": "*"
  }
}
