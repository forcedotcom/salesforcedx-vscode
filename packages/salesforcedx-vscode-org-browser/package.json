{
  "name": "salesforcedx-vscode-org-browser",
  "private": true,
  "displayName": "Salesforce Org Browser",
  "description": "View and retrieve metadata from your Salesforce org",
  "qna": "https://github.com/forcedotcom/salesforcedx-vscode/issues",
  "bugs": {
    "url": "https://github.com/forcedotcom/salesforcedx-vscode/issues"
  },
  "repository": {
    "url": "https://github.com/forcedotcom/salesforcedx-vscode"
  },
  "icon": "images/VSCodeBundle.png",
  "galleryBanner": {
    "color": "#ECECEC",
    "theme": "light"
  },
  "version": "67.3.0",
  "publisher": "salesforce",
  "o11yUploadEndpoint": "https://794testsite.my.site.com/byolwr/webruntime/log/metrics",
  "enableO11y": "true",
  "productFeatureId": "aJCEE0000000mLm4AI",
  "license": "BSD-3-Clause",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "dependencies": {
    "@salesforce/effect-ext-utils": "*",
    "@salesforce/vscode-i18n": "*",
    "effect": "^3.21.2",
    "vscode-uri": "^3.1.0"
  },
  "devDependencies": {
    "@salesforce/core": "^8.31.0",
    "@salesforce/playwright-vscode-ext": "*",
    "@salesforce/source-deploy-retrieve": "^12.32.5",
    "salesforcedx-vscode-services": "*"
  },
  "extensionDependencies": [
    "salesforce.salesforcedx-vscode-services"
  ],
  "scripts": {
    "preinstall": "node ../../scripts/require-root-install.js",
    "vscode:bundle": "wireit",
    "run:web": "wireit",
    "test:web": "wireit",
    "test:web:ui": "DEBUG_MODE=1 npm run test:web -- --headed",
    "test:web:debug": "npm run test:web -- --debug",
    "test:desktop": "wireit",
    "test:desktop:debug": "npm run test:desktop -- --debug",
    "test:e2e": "wireit",
    "prepare:walkthrough-images": "bash scripts/prepare-walkthrough-images.sh",
    "vscode:package": "wireit",
    "vscode:sha256": "node ../../scripts/generate-sha256.js >> ../../SHA256",
    "vscode:publish": "node ../../scripts/publish-vsix.js",
    "compile": "wireit",
    "lint": "wireit",
    "clean": "shx rm -rf node_modules out dist coverage .nyc_output .wireit .eslintcache *.vsix .circular-deps.json",
    "test": "wireit",
    "test:compile": "wireit"
  },
  "wireit": {
    "compile": {
      "command": "tsc --pretty",
      "clean": "if-file-deleted",
      "dependencies": [
        "../effect-ext-utils:compile",
        "../salesforcedx-vscode-i18n:compile",
        "../salesforcedx-vscode-services:compile"
      ],
      "files": [
        "src/**/*.ts",
        "tsconfig.json",
        "../../tsconfig.common.json",
        "package.json",
        "package.nls*.json"
      ],
      "output": [
        "out/**"
      ]
    },
    "test:compile": {
      "command": "tsc -p test/tsconfig.json",
      "dependencies": [
        "compile",
        "../playwright-vscode-ext:compile"
      ],
      "files": [
        "test/**/*.ts",
        "test/tsconfig.json"
      ],
      "output": []
    },
    "vscode:bundle:local": {
      "command": "node ./esbuild.config.mjs",
      "dependencies": [
        "compile",
        "../salesforcedx-vscode-services:vscode:bundle:local"
      ],
      "files": [
        "esbuild.config.mjs",
        "../../scripts/bundling/node.mjs",
        "../../scripts/bundling/web.mjs",
        "out/**"
      ],
      "output": [
        "dist"
      ]
    },
    "vscode:bundle": {
      "command": "node ./esbuild.config.mjs",
      "dependencies": [
        "compile",
        "../salesforcedx-vscode-services:vscode:bundle"
      ],
      "files": [
        "esbuild.config.mjs",
        "../../scripts/bundling/node.mjs",
        "../../scripts/bundling/web.mjs",
        "out/**"
      ],
      "output": [
        "dist"
      ]
    },
    "test": {
      "command": "jest",
      "dependencies": [
        "test:compile"
      ],
      "files": [
        "test/**/*.ts",
        "jest.config.js",
        "../../config/jest.base.config.js"
      ],
      "output": [
        "coverage"
      ]
    },
    "check:circular-deps": {
      "command": "dpdm --no-warning --no-tree --exit-code circular:1 -o .circular-deps.json src",
      "dependencies": [
        "compile"
      ],
      "files": [
        "src/**/*.ts",
        "tsconfig.json",
        "../../tsconfig.common.json"
      ],
      "output": [
        ".circular-deps.json"
      ]
    },
    "lint": {
      "command": "eslint --color --cache --cache-location .eslintcache .",
      "dependencies": [
        "../eslint-local-rules:compile",
        "check:circular-deps",
        "compile"
      ],
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        "../../eslint.config.mjs",
        ".vscodeignore",
        "package.json",
        "package.nls.json"
      ],
      "output": []
    },
    "vscode:package": {
      "command": "vsce package",
      "dependencies": [
        "vscode:bundle"
      ],
      "files": [
        "package.json",
        "package.nls*.json",
        "README.md",
        "CHANGELOG.md",
        "LICENSE.txt",
        "images/**",
        "resources/**"
      ],
      "output": [
        "*.vsix"
      ]
    },
    "test:web": {
      "command": "playwright test --config=test/playwright/playwright.config.web.ts",
      "env": {
        "PLAYWRIGHT_WORKERS": {
          "external": true
        }
      },
      "dependencies": [
        "vscode:bundle",
        "../salesforcedx-vscode-services:vscode:bundle",
        "../salesforcedx-vscode-services:spans:server",
        "../playwright-vscode-ext:compile"
      ],
      "files": [
        "test/playwright/**/*.ts",
        "package*.json"
      ],
      "output": []
    },
    "test:desktop": {
      "command": "playwright test --config=test/playwright/playwright.config.desktop.ts",
      "env": {
        "VSCODE_DESKTOP": "1",
        "E2E_FROM_VSIX": {
          "external": true
        },
        "PLAYWRIGHT_WORKERS": {
          "external": true
        }
      },
      "dependencies": [
        "vscode:package",
        "../salesforcedx-vscode-services:vscode:package",
        "../salesforcedx-vscode-services:spans:server",
        "../playwright-vscode-ext:compile"
      ],
      "files": [
        "test/playwright/**/*.ts",
        "package*.json"
      ],
      "output": []
    },
    "test:e2e": {
      "dependencies": [
        "test:web",
        "test:desktop"
      ]
    },
    "run:web": {
      "command": "npx vscode-test-web --browserType=chromium --browserOption=--disable-web-security --browserOption=--remote-debugging-port=9222 --extensionDevelopmentPath . --extensionPath ../salesforcedx-vscode-services --extensionPath ../salesforcedx-vscode-metadata --open-devtools --port 3001 --quality stable --verbose --printServerLog",
      "service": true,
      "dependencies": [
        "vscode:bundle",
        "../salesforcedx-vscode-services:vscode:bundle"
      ],
      "files": [
        "test/playwright/**/*.ts"
      ]
    }
  },
  "main": "./dist/index.js",
  "browser": "./dist/web/index.js",
  "contributes": {
    "walkthroughs": [
      {
        "id": "sf.org-browser",
        "title": "%org_browser_walkthrough_title%",
        "description": "%org_browser_walkthrough_description%",
        "steps": [
          {
            "id": "open-org-browser",
            "title": "%org_browser_walkthrough_open_title%",
            "description": "%org_browser_walkthrough_open_description%",
            "media": {
              "image": "images/walkthrough/org-browser-retrieve.png",
              "altText": "%org_browser_walkthrough_open_alt%"
            },
            "completionEvents": [
              "onCommand:workbench.view.extension.metadata"
            ]
          },
          {
            "id": "pending-changes",
            "title": "%org_browser_walkthrough_pending_changes_title%",
            "description": "%org_browser_walkthrough_pending_changes_description%",
            "media": {
              "image": "images/walkthrough/org-browser.png",
              "altText": "%org_browser_walkthrough_pending_changes_alt%"
            }
          },
          {
            "id": "filter-and-view-modes",
            "title": "%org_browser_walkthrough_filter_title%",
            "description": "%org_browser_walkthrough_filter_description%",
            "media": {
              "image": "images/walkthrough/org-browser-browse.png",
              "altText": "%org_browser_walkthrough_filter_alt%"
            },
            "completionEvents": [
              "onCommand:sf.org-browser.filterTypes"
            ]
          },
          {
            "id": "sync-actions",
            "title": "%org_browser_walkthrough_sync_title%",
            "description": "%org_browser_walkthrough_sync_description%",
            "media": {
              "image": "images/walkthrough/org-browser-file-opened.png",
              "altText": "%org_browser_walkthrough_sync_alt%"
            }
          },
          {
            "id": "custom-object-fields",
            "title": "%org_browser_walkthrough_custom_object_title%",
            "description": "%org_browser_walkthrough_custom_object_description%",
            "media": {
              "image": "images/walkthrough/org-browser-browse.png",
              "altText": "%org_browser_walkthrough_custom_object_alt%"
            }
          }
        ]
      }
    ],
    "viewsWelcome": [
      {
        "view": "sfdxOrgBrowser",
        "contents": "Loading metadata from your org...\n\nThe Org Browser shows your org and local project together with live sync status. Conflicts, remote changes, and local changes are surfaced automatically.\n\nUse view modes to focus on what matters, filter by type or state, and retrieve, deploy, or preview — all without leaving the editor."
      },
      {
        "view": "sfdxOrgBrowserExplorer",
        "contents": "Loading metadata from your org...\n\nThe Org Browser shows your org and local project together with live sync status. Conflicts, remote changes, and local changes are surfaced automatically.\n\nUse view modes to focus on what matters, filter by type or state, and retrieve, deploy, or preview — all without leaving the editor."
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "metadata",
          "title": "%orgBrowser.activitybar.title%",
          "icon": "resources/orgBrowserIcon.svg"
        }
      ]
    },
    "views": {
      "metadata": [
        {
          "id": "sfdxOrgBrowser",
          "name": "%orgBrowser.view.name%",
          "when": "sf:has_target_org"
        }
      ],
      "explorer": [
        {
          "id": "sfdxOrgBrowserExplorer",
          "name": "%orgBrowser.view.explorerName%",
          "when": "sf:has_target_org",
          "visibility": "collapsed"
        }
      ]
    },
    "commands": [
      {
        "command": "sf.org-browser.walkthrough.open",
        "title": "%org_browser_walkthrough_open_command%",
        "category": "Org Browser"
      },
      {
        "command": "sfdxOrgBrowser.refreshType",
        "title": "%orgBrowser.command.refreshType%",
        "category": "Org Browser",
        "icon": {
          "light": "resources/light/refresh.svg",
          "dark": "resources/dark/refresh.svg"
        }
      },
      {
        "command": "sfdxOrgBrowser.retrieveMetadata",
        "title": "%orgBrowser.command.retrieveMetadata%",
        "icon": "$(cloud-download)"
      },
      {
        "command": "sfdxOrgBrowser.collapseAll",
        "title": "%orgBrowser.command.collapseAll%",
        "category": "Org Browser",
        "icon": "$(collapse-all)"
      },
      {
        "command": "sfdxOrgBrowser.pullRemoteChange",
        "title": "%orgBrowser.command.pullRemoteChange%",
        "category": "Org Browser",
        "icon": "$(cloud-download)"
      },
      {
        "command": "sfdxOrgBrowser.deployLocalChange",
        "title": "%orgBrowser.command.deployLocalChange%",
        "category": "Org Browser",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "sfdxOrgBrowser.openLocalComponent",
        "title": "%orgBrowser.command.openLocalComponent%",
        "category": "Org Browser",
        "icon": "$(go-to-file)"
      },
      {
        "command": "sfdxOrgBrowser.previewOrgComponent",
        "title": "%orgBrowser.command.previewOrgComponent%",
        "category": "Org Browser",
        "icon": "$(open-preview)"
      },
      {
        "command": "sfdxOrgBrowser.createComponent",
        "title": "%orgBrowser.command.createComponent%",
        "category": "Org Browser",
        "icon": "$(add)"
      },
      {
        "command": "sfdxOrgBrowser.viewModeLocalOnly",
        "title": "%orgBrowser.command.viewModeLocalOnly%",
        "category": "Org Browser",
        "icon": "$(eye-closed)"
      },
      {
        "command": "sfdxOrgBrowser.viewModeWithContent",
        "title": "%orgBrowser.command.viewModeWithContent%",
        "category": "Org Browser",
        "icon": "$(eye)"
      },
      {
        "command": "sfdxOrgBrowser.viewModeOrgOnly",
        "title": "%orgBrowser.command.viewModeOrgOnly%",
        "category": "Org Browser",
        "icon": "$(cloud)"
      },
      {
        "command": "sfdxOrgBrowser.viewModeAllTypes",
        "title": "%orgBrowser.command.viewModeAllTypes%",
        "category": "Org Browser",
        "icon": "$(list-flat)"
      },
      {
        "command": "sfdxOrgBrowser.filterTypes",
        "title": "%orgBrowser.command.filterTypes%",
        "category": "Org Browser",
        "icon": "$(filter)"
      },
      {
        "command": "sfdxOrgBrowser.clearFilter",
        "title": "%orgBrowser.command.clearFilter%",
        "category": "Org Browser",
        "icon": "$(filter-filled)"
      },
      {
        "command": "sfdxOrgBrowser.retrieveAllFiltered",
        "title": "%orgBrowser.command.retrieveAllFiltered%",
        "category": "Org Browser",
        "icon": "$(cloud-download)"
      },
      {
        "command": "sfdxOrgBrowser.pullAllRemoteChanges",
        "title": "%orgBrowser.command.pullAllRemoteChanges%",
        "category": "Org Browser",
        "icon": "$(cloud-download)"
      },
      {
        "command": "sfdxOrgBrowser.deployAllLocalChanges",
        "title": "%orgBrowser.command.deployAllLocalChanges%",
        "category": "Org Browser",
        "icon": "$(cloud-upload)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "sfdxOrgBrowser.refreshType",
          "when": "view =~ /^sfdxOrgBrowser/",
          "group": "navigation@0"
        },
        {
          "command": "sfdxOrgBrowser.collapseAll",
          "when": "view =~ /^sfdxOrgBrowser/",
          "group": "navigation@1"
        },
        {
          "command": "sfdxOrgBrowser.viewModeWithContent",
          "when": "view =~ /^sfdxOrgBrowser/ && !sf:orgBrowser.viewMode",
          "group": "navigation@2"
        },
        {
          "command": "sfdxOrgBrowser.viewModeWithContent",
          "when": "view =~ /^sfdxOrgBrowser/ && sf:orgBrowser.viewMode == withContent",
          "group": "navigation@2"
        },
        {
          "command": "sfdxOrgBrowser.viewModeAllTypes",
          "when": "view =~ /^sfdxOrgBrowser/ && sf:orgBrowser.viewMode == allTypes",
          "group": "navigation@2"
        },
        {
          "command": "sfdxOrgBrowser.viewModeLocalOnly",
          "when": "view =~ /^sfdxOrgBrowser/ && sf:orgBrowser.viewMode == localOnly",
          "group": "navigation@2"
        },
        {
          "command": "sfdxOrgBrowser.viewModeOrgOnly",
          "when": "view =~ /^sfdxOrgBrowser/ && sf:orgBrowser.viewMode == orgOnly",
          "group": "navigation@2"
        },
        {
          "command": "sfdxOrgBrowser.retrieveAllFiltered",
          "when": "view =~ /^sfdxOrgBrowser/",
          "group": "navigation@4"
        },
        {
          "command": "sfdxOrgBrowser.filterTypes",
          "when": "view =~ /^sfdxOrgBrowser/ && !sf:orgBrowser.filterActive",
          "group": "navigation@3"
        },
        {
          "command": "sfdxOrgBrowser.clearFilter",
          "when": "view =~ /^sfdxOrgBrowser/ && sf:orgBrowser.filterActive",
          "group": "navigation@3"
        }
      ],
      "commandPalette": [
        {
          "command": "sf.org-browser.walkthrough.open",
          "when": "sf:has_target_org"
        }
      ],
      "view/item/context": [
        {
          "command": "sfdxOrgBrowser.refreshType",
          "when": "view =~ /^sfdxOrgBrowser/ && viewItem =~ /^(type|customObject|folderType|folder|changesRoot|changesGroup)/",
          "group": "inline"
        },
        {
          "command": "sfdxOrgBrowser.retrieveMetadata",
          "when": "view =~ /^sfdxOrgBrowser/ && viewItem =~ /^(type|customObject|component)/ && viewItem != component_localAdded_local",
          "group": "inline"
        },
        {
          "command": "sfdxOrgBrowser.pullRemoteChange",
          "when": "view =~ /^sfdxOrgBrowser/ && viewItem =~ /^changedComponent_remote/",
          "group": "inline"
        },
        {
          "command": "sfdxOrgBrowser.deployLocalChange",
          "when": "view =~ /^sfdxOrgBrowser/ && viewItem =~ /local(Added|Modified|Deleted)/",
          "group": "inline"
        },
        {
          "command": "sfdxOrgBrowser.openLocalComponent",
          "when": "view =~ /^sfdxOrgBrowser/ && viewItem =~ /_local/ && !(viewItem =~ /localDeleted/)",
          "group": "inline"
        },
        {
          "command": "sfdxOrgBrowser.previewOrgComponent",
          "when": "view =~ /^sfdxOrgBrowser/ && viewItem =~ /_previewable/",
          "group": "inline"
        },
        {
          "command": "sfdxOrgBrowser.createComponent",
          "when": "view =~ /^sfdxOrgBrowser/ && viewItem =~ /_creatable$/",
          "group": "inline"
        },
        {
          "command": "sfdxOrgBrowser.pullAllRemoteChanges",
          "when": "view =~ /^sfdxOrgBrowser/ && viewItem == changesGroup_remote",
          "group": "inline"
        },
        {
          "command": "sfdxOrgBrowser.deployAllLocalChanges",
          "when": "view =~ /^sfdxOrgBrowser/ && viewItem == changesGroup_local",
          "group": "inline"
        }
      ]
    }
  }
}
