{
  "extends": "../../tsconfig.common.json",
  "compilerOptions": {
    "outDir": "out",
    "rootDir": "src",
    "declaration": true,
    "emitDeclarationOnly": true,
    "skipLibCheck": true,
    "plugins": [
      {
        "name": "@effect/language-service"
      }
    ]
