{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(VSCODE_DESKTOP=1 npm run test:desktop *)",
      "Bash(VSCODE_DESKTOP=1 WIREIT_CACHE=none npm run test:desktop *)",
      "Bash(pkill *)",
      "Bash(done)",
      "Bash(chmod:*)",
      "Bash(WIREIT_CACHE=none npm run *)",
      "Bash(sf org:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:code.visualstudio.com)",
      "Bash(find .vscode-test-web/ -name *.json)",
      "Bash(gh api:*)",
      "Bash(python3 -c \"import json,sys; reviews=json.load\\(sys.stdin\\); [print\\(f''''Review {r[\"\"id\"\"]} by {r[\"\"user\"\"][\"\"login\"\"]}: {r[\"\"state\"\"]}''''\\) for r in reviews]\")",
      "Bash(brew list:*)",
      "Read(//opt/homebrew/bin/**)",
      "Read(//Users/madhur.shrivastava/bin/**)",
      "Bash(source ~/.zshrc)",
      "Bash(python3:*)",
      "Bash(grep -rn \"lwc_component_name\\\\|lwc_select\\\\|lwc_output\" /Users/madhur.shrivastava/salesforcedx-vscode/packages/salesforcedx-vscode-metadata/src --include=*.ts)",
      "Bash(npx tsc:*)",
      "Bash(grep -r \"import.*Response\\\\|from.*commandletHelpers\" /Users/madhur.shrivastava/salesforcedx-vscode/packages/salesforcedx-vscode-apex-testing/src/ --include=*.ts)",
      "Bash(git:*)"
    ],
    "autoApprove": [
      "PostToolUse",
      "Stop",
      "PreToolUse"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd $(git rev-parse --show-toplevel) && .claude/hooks/mark-edit.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(git * --no-verify *)",
        "hooks": [
          {
            "type": "command",
            "command": "cd $(git rev-parse --show-toplevel) && .claude/hooks/block-no-verify.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd $(git rev-parse --show-toplevel) && .claude/hooks/verify-stop.sh"
          }
        ]
      }
    ]
  }
}
