{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(VSCODE_DESKTOP=1 npm run test:desktop *)",
      "Bash(VSCODE_DESKTOP=1 WIREIT_CACHE=none npm run test:desktop *)",
      "Bash(pkill *)",
      "Bash(done)",
      "Bash(chmod:*)",
      "Bash(WIREIT_CACHE=none npm run *)",
      "Bash(sf org:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:code.visualstudio.com)",
      "Bash(npx tsc:*)",
      "Bash(python3 *)",
      "Read(//private/tmp/test-lwc-jest/**)",
      "Bash(./node_modules/.bin/lwc-jest -- --json --outputFile /tmp/test-result2.json --testLocationInResults --runTestsByPath force-app/main/default/lwc/lwc1/__tests__/lwc1.test.js)",
      "Bash(echo \"Exit: $?\")",
      "Read(//tmp/**)",
      "Bash(./node_modules/.bin/lwc-jest -- --json --outputFile /tmp/test-result3.json --testLocationInResults --runTestsByPath /private/tmp/test-lwc-jest/force-app/main/default/lwc/lwc1/__tests__/lwc1.test.js)",
      "Bash(npx playwright *)",
      "Bash(VSCODE_DESKTOP=1 npx playwright *)"
    ],
    "autoApprove": [
      "PostToolUse",
      "Stop",
      "PreToolUse"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd $(git rev-parse --show-toplevel) && .claude/hooks/mark-edit.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(git * --no-verify *)",
        "hooks": [
          {
            "type": "command",
            "command": "cd $(git rev-parse --show-toplevel) && .claude/hooks/block-no-verify.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd $(git rev-parse --show-toplevel) && .claude/hooks/verify-stop.sh"
          }
        ]
      }
    ]
  }
}
